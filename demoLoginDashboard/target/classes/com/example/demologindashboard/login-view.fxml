<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="250" prefWidth="300" spacing="10"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.demologindashboard.LoginController">

  <Label text="LoginAccount" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

  <HBox spacing="5" alignment="CENTER">
    <Label text="Usuario:" />
    <TextField fx:id="txtUser" prefHeight="25" prefWidth="150" promptText="Usuario" />
  </HBox>

  <HBox spacing="5" alignment="CENTER">
    <Label text="Correo:" />
    <TextField fx:id="txtEmail" prefHeight="25" prefWidth="150" promptText="Correo" />
  </HBox>

  <HBox spacing="5" alignment="CENTER">
    <Label text="Contraseña:" />
    <PasswordField fx:id="txtPassword" prefHeight="25" prefWidth="150" promptText="Contraseña" />
  </HBox>

  <Button onAction="#onLoginClick" text="Login" />
  <Label fx:id="lblError" text="" style="-fx-text-fill: red;" />

</VBox>